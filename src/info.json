{
  "identifier": "com.windfade.urban-dictionary",
  "version": "0.2.0",
  "category": "translate",
  "name": "Urban Dictionary",
  "summary": "Search slang meanings on Urban Dictionary with GPT analysis",
  "author": "WindFade",
  "homepage": "https://github.com/a322655/bob-plugin-urban-dictionary",
  "minBobVersion": "0.5.0",
  "options": [
    {
      "identifier": "apiKey",
      "type": "text",
      "title": "OpenAI API Key",
      "desc": "Required for GPT analysis. Get one from https://platform.openai.com/account/api-keys",
      "textConfig": {
        "type": "secure",
        "placeholderText": "sk-..."
      }
    },
    {
      "identifier": "model",
      "type": "menu",
      "title": "OpenAI Model",
      "desc": "Select which model to use for analysis",
      "defaultValue": "gpt-5.2",
      "menuValues": [
        {
          "title": "GPT-5.2",
          "value": "gpt-5.2"
        },
        {
          "title": "GPT-5.2 Pro",
          "value": "gpt-5.2-pro"
        },
        {
          "title": "GPT-5.2 Chat (Latest)",
          "value": "gpt-5.2-chat-latest"
        },
        {
          "title": "GPT-5 Mini",
          "value": "gpt-5-mini"
        },
        {
          "title": "GPT-5 Nano",
          "value": "gpt-5-nano"
        },
        {
          "title": "Custom",
          "value": "custom"
        }
      ]
    },
    {
      "identifier": "customModel",
      "type": "text",
      "title": "Custom Model Name",
      "desc": "Enter custom model name when 'Custom' is selected above (e.g., gpt-4o-mini)",
      "textConfig": {
        "type": "visible",
        "placeholderText": "gpt-4o-mini"
      }
    }
  ]
}
